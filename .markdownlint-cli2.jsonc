{
  "noBanner": true,
  "noProgress": true,
  "globs": [
    "README.md",
    "AGENTS.md",
    "config/**/*.md",
    "models/**/*.md",
    "doc/**/*.md",
    "site/**/*.md"
  ],
  "ignores": [
    "reference/**",
    "site/_build/**",
    ".git/**",
    ".temp/**",
    ".tools/**",
    ".vs/**",
    "isolated/**",
    "output/**",
    "**/__pycache__/**"
  ],
  "config": {
    "default": true,
    "MD013": false,
    "MD029": false,
    "MD024": {
      "siblings_only": true
    }
  }
}
